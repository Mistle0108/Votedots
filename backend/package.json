{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && node scripts/copy-static-assets.mjs",
    "dev": "nodemon --exec ts-node src/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:infra:up": "docker compose -f ../docker-compose.test.yml up -d",
    "test:infra:down": "docker compose -f ../docker-compose.test.yml down -v",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "migration:generate": "ts-node --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/database/data-source.ts",
    "migration:run": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:revert": "ts-node --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jpeg-js": "^0.4.4",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
